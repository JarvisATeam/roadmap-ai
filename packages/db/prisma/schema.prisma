// Prisma Schema for roadmap-ai monorepo
// Used by both FlowArk Solo and Revenue OS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // FlowArk Solo relations
  dayBlocks        DayBlock[]
  frustrationLogs  FrustrationLog[]
  habitStreaks     HabitStreak[]
  consequenceRules ConsequenceRule[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// FLOWARK SOLO
// ============================================================

model DayBlock {
  id          String    @id @default(cuid())
  userId      String
  date        DateTime  @db.Date
  period      BlockPeriod
  task        String?
  duration    Int?      // minutes
  isCompleted Boolean   @default(false)
  isLocked    Boolean   @default(false)
  lockedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, period])
  @@map("day_blocks")
}

enum BlockPeriod {
  MORNING    // 06:00-12:00
  AFTERNOON  // 12:00-17:00
  EVENING    // 17:00-22:00
}

model FrustrationLog {
  id        String   @id @default(cuid())
  userId    String
  text      String   @db.Text
  tapPoint  String   // predefined category
  severity  Int      // 1-5
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("frustration_logs")
}

model HabitStreak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habit_streaks")
}

model ConsequenceRule {
  id          String   @id @default(cuid())
  userId      String
  name        String
  condition   String   // e.g. "missed_blocks_3_in_7_days"
  consequence String   // e.g. "lock_features"
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consequence_rules")
}

// ============================================================
// REVENUE OS
// ============================================================

model StripeEvent {
  id          String   @id
  type        String
  data        Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@map("stripe_events")
}

model MRRSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  mrr       Float
  arr       Float
  customers Int
  churn     Float
  newMrr    Float    @default(0)
  expansion Float    @default(0)
  createdAt DateTime @default(now())

  @@unique([date])
  @@map("mrr_snapshots")
}

model DeploymentLog {
  id          String   @id @default(cuid())
  service     String
  environment String
  status      String
  deployedAt  DateTime
  commitSha   String?
  duration    Int?     // seconds
  createdAt   DateTime @default(now())

  @@map("deployment_logs")
}
