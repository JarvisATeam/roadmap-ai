{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Task",
  "description": "Canonical task schema for agent orchestration",
  "type": "object",
  "required": ["task_id", "agent_role", "verb", "status", "created_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9a-f]{8}$",
      "description": "Unique task identifier (task-xxxxxxxx)"
    },
    "agent_role": {
      "type": "string",
      "enum": ["GINIE", "AVA", "CODEX", "DISPATCH", "HUMAN_ONLY"],
      "description": "Target agent role"
    },
    "verb": {
      "type": "string",
      "enum": ["propose", "validate", "execute", "review", "approve", "reject", "defer"],
      "description": "Action verb"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "proposed", "approved", "dispatched", "running", "blocked", "failed", "done"],
      "description": "Current task status"
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Priority level (1=low, 5=critical)"
    },
    "mission_id": {
      "type": "string",
      "description": "Associated mission UUID"
    },
    "step_id": {
      "type": "string",
      "description": "Associated step UUID"
    },
    "payload": {
      "type": "object",
      "description": "Task-specific data"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "dispatched_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "blocked_reason": {
      "type": "string",
      "description": "Reason if status=blocked"
    },
    "error": {
      "type": "string",
      "description": "Error message if status=failed"
    }
  }
}
